{
    "name": "forgemvc/framework",
    "description": "ForgeMVC Framework",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
